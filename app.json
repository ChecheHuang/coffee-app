{
  "expo": {
    "name": "BrewMaster Pro",
    "slug": "brewmaster-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "brewmaster",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alphacore.brewmaster"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1C"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.alphacore.brewmaster"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
